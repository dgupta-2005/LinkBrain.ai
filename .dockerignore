# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
.venv/
venv/
env/
ENV/

# Secrets and Environment Variables (Don't build your local keys into the image!)
.env
.env.*
env.yaml

# Local Databases (Google Cloud will use Supabase)
*.db
*.sqlite
*.sqlite3
database_v2.db

# Logs and debug files
*.log
err.log
available_models.txt

# OS generated files
.DS_Store
Thumbs.db

# Git stuff
.git
.gitignore
